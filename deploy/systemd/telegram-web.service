[Unit]
Description=Telegram Offers Bot - web dashboard
After=network.target

[Service]
Type=simple
User=telegrambot
Group=telegrambot
WorkingDirectory=/opt/bot_telegram
ExecStart=/opt/bot_telegram/venv/bin/python /opt/bot_telegram/bot.py web
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target