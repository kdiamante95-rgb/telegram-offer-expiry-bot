# Telegram bot
TELEGRAM_BOT_TOKEN=put-your-bot-token-here
TELEGRAM_TARGET_CHAT_ID=@yourchannel

# Web dashboard
FLASK_SECRET_KEY=put-a-long-random-secret-key-here
DASHBOARD_PASSWORD=put-a-long-password-here
SESSION_COOKIE_SECURE=true
WEBAPP_HOST=127.0.0.1
WEBAPP_PORT=8080
APP_TIMEZONE=Europe/Rome

# Optional: use the numeric channel id instead of the public handle
# TELEGRAM_TARGET_CHAT_ID=-1001234567890